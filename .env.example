# ─────────────────────────────────────────────────────────────────────────
# Weehan Math Tuition — environment variables
#
# Copy this file to `.env.local` and fill in what you have. EVERY variable is
# optional: with none set, the site still runs and the enquiry form still
# "succeeds" locally (leads are logged to the server console instead of stored
# or emailed). Add each key when you're ready — no code changes needed.
#
# NEXT_PUBLIC_* values are exposed to the browser (needed for client widgets).
# All others are server-only secrets — never prefix a secret with NEXT_PUBLIC_.
# On Vercel, set these in Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────

# Canonical site URL (no trailing slash). Used for SEO, OG, sitemap, robots.
NEXT_PUBLIC_SITE_URL="https://weehanmathtuition.com"

# WhatsApp Business number, E.164 DIGITS ONLY (country code, no "+" or spaces).
# Example for +65 8123 4567 → 6581234567
NEXT_PUBLIC_WHATSAPP_NUMBER="6580000000"

# ── Cloudflare Turnstile (anti-spam) ──────────────────────────────────────
# Create a free widget at https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ── Lead datastore (Google Sheets via Apps Script webhook) ────────────────
# See README "Google Sheets" for the 4-step Apps Script setup. Paste the
# deployed web-app URL here. Leave blank to log leads to the console instead.
SHEETS_WEBHOOK_URL=""

# ── Email (Resend) ────────────────────────────────────────────────────────
# https://resend.com → API Keys. RESEND_FROM must be a verified sender/domain.
RESEND_API_KEY=""
RESEND_FROM="Weehan Math Tuition <hello@weehanmathtuition.com>"
# Where new-lead notifications go. Defaults to the address in content/site.ts.
LEAD_NOTIFICATION_EMAIL=""

# ── Analytics (Plausible) ─────────────────────────────────────────────────
# Your Plausible site's domain, e.g. "weehanmathtuition.com". Leave blank to
# disable the analytics script entirely.
NEXT_PUBLIC_ANALYTICS_DOMAIN=""
